Description: Install runtime data under /usr/share/opendoor for Debian packages
 Debian packages must not install application data directly under /usr.
 This patch keeps source-checkout and wheel compatibility while adding the
 Debian runtime data path under /usr/share/opendoor/data.
Author: Stanislav Menshykh <exbay.pro@gmail.com>
Forwarded: not-needed

diff --git a/setup.py b/setup.py
index c70415d..b995c74 100644
--- a/setup.py
+++ b/setup.py
@@ -72,9 +72,9 @@ setup(
     packages=find_packages(exclude=('tests', 'tests.*')),
     include_package_data=True,
     data_files=[
-        ('.', ['opendoor.conf']),
+        ('share/opendoor', ['opendoor.conf']),
         (
-            'data',
+            'share/opendoor/data',
             [
                 'data/directories.dat',
                 'data/ignored.dat',
@@ -84,13 +84,13 @@ setup(
             ],
         ),
         (
-            'data/openvpn-profiles',
+            'share/opendoor/data/openvpn-profiles',
             [
                 'data/openvpn-profiles/example.ovpn',
             ],
         ),
         (
-            'data/wireguard-profiles',
+            'share/opendoor/data/wireguard-profiles',
             [
                 'data/wireguard-profiles/example.conf',
             ],
diff --git a/src/core/core.py b/src/core/core.py
index e668b63..5ca5b28 100644
--- a/src/core/core.py
+++ b/src/core/core.py
@@ -57,6 +57,8 @@ def resolve_data_root() -> Path:
 
     candidates = [
         PROJECT_ROOT / 'data',
+        Path(py_sys.prefix) / 'share' / 'opendoor' / 'data',
+        Path(py_sys.base_prefix) / 'share' / 'opendoor' / 'data',
         Path(py_sys.prefix) / 'data',
         Path(py_sys.base_prefix) / 'data',
     ]
