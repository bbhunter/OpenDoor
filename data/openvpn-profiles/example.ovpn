client
dev tun
proto udp
remote vpn.example.com 1194

resolv-retry infinite
nobind
persist-key
persist-tun
verb 3

remote-cert-tls server
auth SHA256
cipher AES-256-GCM

# Copy this file locally and provide your own OpenVPN credentials.
#
# Certificate-based setup example:
# ca /path/to/ca.crt
# cert /path/to/client.crt
# key /path/to/client.key
#
# Username/password setup example:
# auth-user-pass /path/to/auth.txt
